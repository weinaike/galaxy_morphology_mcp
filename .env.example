# OpenAI API Configuration (for ANALYSIS_MODE=vlm, default)
# Copy this file to .env and fill in your API keys

# OpenAI API Key (required)
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI Base URL (optional, for compatible API endpoints)
OPENAI_BASE_URL=

# OpenAI Model to use (optional, defaults to gpt-4o)
OPENAI_MODEL=gpt-4o

# Claude Code Agent SDK Configuration (for ANALYSIS_MODE=cc)
# Uses CLAUDECODE_ prefix to avoid conflicts with Claude Code's own env vars
#
# The cc mode calls Anthropic API via claude-agent-sdk. If you want to use
# a non-Anthropic model (e.g. a third-party LLM) as the analysis backend,
# install and run Claude Code Router as a local proxy:
#
# See: https://github.com/musistudio/claude-code-router
#
# Claude Code Router translates the Anthropic Messages API format to the
# target provider's format automatically, so claude-agent-sdk can work
# with any compatible LLM endpoint.

CLAUDECODE_API_KEY=your_anthropic_api_key_here
CLAUDECODE_BASE_URL=
CLAUDECODE_MODEL=claude-3-5-sonnet-latest

# Gemini CLI Agent SDK Configuration (for ANALYSIS_MODE=acp)
ACP_GOOGLE_GEMINI_BASE_URL=
ACP_GEMINI_API_KEY=
ACP_GEMINI_MODEL=gemini-3-flash-preview

# Analysis backend for component_analysis: vlm (default), cc, or acp
#   vlm — multi-turn (3 focused turns) via OpenAI SDK (OPENAI_* env vars)
#   cc  — Claude Agent SDK (CLAUDECODE_* env vars)
#   acp — Gemini CLI via ACP protocol (ACP_GEMINI_* env vars)
ANALYSIS_MODE=vlm

# GALFITS Executable Path, environment, and Data Path
GALFITS_BIN="/home/wnk/miniconda3/envs/galfits/bin/python /home/wnk/code/GalfitS/galfits/galfits.py"
GS_DATA_PATH=/home/wnk/code/GalfitS

# visualRAG online retrieval service (for ANALYSIS_MODE=vlm Few-shot reference).
# When set, component_analysis queries this service in turn-1 and injects
# baseline/hard-negative/positive reference cases (image + caption) before the
# target. Leave VISUALRAG_SERVICE_URL empty to disable (degrades to single-image).
VISUALRAG_SERVICE_URL=http://127.0.0.1:8765
VISUALRAG_ENABLED=1
VISUALRAG_TOP_K=1
VISUALRAG_STRATEGY=both

BEST_ROUND_TRACKING=1