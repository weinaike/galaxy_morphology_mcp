# OpenAI API Configuration
# Copy this file to .env and fill in your API keys

# OpenAI API Key (required for analyze_by_vlm function)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI Base URL (optional, for using compatible API endpoints)
# Leave empty to use the default OpenAI API endpoint
# Example: https://api.openai.com/v1 (default) or custom endpoint
OPENAI_BASE_URL=

# OpenAI Model to use (optional, defaults to gpt-4o)
# Supported multimodal models: gpt-4o, gpt-4o-mini, gpt-4-vision-preview
OPENAI_MODEL=gpt-4o

# Claude Code Agent SDK Configuration (for ANALYSIS_MODE=cc)
# Uses CLAUDECODE_ prefix to avoid conflicts with Claude Code's own env vars
#
# The cc mode calls Anthropic API via claude-agent-sdk. If you want to use
# a non-Anthropic model (e.g. a third-party LLM) as the analysis backend,
# install and run Claude Code Router as a local proxy:
#
# See: https://github.com/musistudio/claude-code-router
#
# Claude Code Router translates the Anthropic Messages API format to the
# target provider's format automatically, so claude-agent-sdk can work
# with any compatible LLM endpoint.

CLAUDECODE_API_KEY=your_anthropic_api_key_here
CLAUDECODE_BASE_URL=
CLAUDECODE_MODEL=claude-3-5-sonnet-latest

# Analysis backend for component_analysis: vlm (default) or cc
ANALYSIS_MODE=vlm

# GALFITS Executable Path, environment, and Data Path
GALFITS_BIN="/home/wnk/miniconda3/envs/galfits/bin/python /home/wnk/code/GalfitS/galfits/galfits.py"
GS_DATA_PATH=/home/wnk/code/GalfitS