================================================================================
# IMAGE and GALFIT CONTROL PARAMETERS
A) image.fit          # Input data image (FITS file)
B) galfit_2bulges.fit # Output data image block
C) sigma.fit      # Sigma image name (made from data if blank or none)
D) psf.fit   # Data_name PSF image and (optional) diffusion kernel
E) 1                                                              # PSF fine sampling factor relative to data
F) mask.fit        # Bad pixel mask (FITS image or ASCII coord list)
G) none                         # File with parameter constraints (ASCII file)
H) 50   200  50   200     # Image region to fit (xmin xmax ymin ymax)
I) 55      55                # Size of the convolution box (x y)
J) 22.5                   # Magnitude photometric zeropoint
K) 0.396  0.396                # Plate scale (dx dy)   [arcsec per pixel]
O) regular                   # Display type (regular, curses, both)
P) 0                         # Choose: 0=optimize, 1=model, 2=imgblock, 3=subcomps
# INITIAL FITTING PARAMETERS
# ------------------------------------------------------------------------------
# Object number: 1 - Bulge 1 (de Vaucouleurs profile)
0) sersic                    #  Component type
1) 128.09  127.95  1  1    #  Position x, y
3) 14.88        1           #  Integrated magnitude
4) 30.81        1           #  R_e (effective radius)   [pix]
5) 16.0         1           #  Sersic index n (de Vaucouleurs n=4)
6) 0.0000        0           #     -----
7) 0.0000        0           #     -----
8) 0.0000        0           #     -----
9) 0.96          1           #  Axis ratio (b/a)
10) -83.50       1           #  Position angle (PA) [deg: Up=0, Left=90]
Z) 0                         #  Skip this model in output image?  (yes=1, no=0)

# Object number: 2 - Bulge 2 (de Vaucouleurs profile)
0) sersic                    #  Component type
1) 128.09  127.95  1  1    #  Position x, y
3) 18.0         1           #  Integrated magnitude
4) 10.0         1           #  R_e (effective radius)   [pix]
5) 4            1           #  Sersic index n (de Vaucouleurs n=4)
6) 0.0000        0           #     -----
7) 0.0000        0           #     -----
8) 0.0000        0           #     -----
9) 0.90          1           #  Axis ratio (b/a)
10) -75.83       1           #  Position angle (PA) [deg: Up=0, Left=90]
Z) 0                         #  Skip this model in output image?  (yes=1, no=0)

# Object number: 3 - Disk (exponential profile)
0) sersic                    #  Component type
1) 128.23  128.11  1  1    #  Position x, y
3) 17.29        1           #  Integrated magnitude
4) 15.35        1           #  R_e (effective radius)   [pix]
5) 0.33         1           #  Sersic index n (exponential disk)
6) 0.0000        0           #     -----
7) 0.0000        0           #     -----
8) 0.0000        0           #     -----
9) 0.39          1           #  Axis ratio (b/a)
10) -75.83       1           #  Position angle (PA) [deg: Up=0, Left=90]
Z) 0                         #  Skip this model in output image?  (yes=1, no=0)

# Object number: 4 - Sky
0) sky                       #  Component type
1) -6.00e-04   1           #  Sky background at center of fitting region [ADUs]
2) 0.0000        0           #  dsky/dx (sky gradient in x)     [ADUs/pix]
3) 0.0000        0           #  dsky/dy (sky gradient in y)     [ADUs/pix]
Z) 0                         #  Skip this model in output image?  (yes=1, no=0)
================================================================================
